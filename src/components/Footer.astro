<footer class="bg-slate-950 border-t border-primary/10 py-16 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-10">
        <div class="space-y-4 text-center md:text-left">
            <div class="flex items-center gap-3 justify-center md:justify-start">
                <span class="material-symbols-outlined text-3xl text-primary">insights</span>
                <h2 class="text-xl font-black uppercase italic">Expert.Ads</h2>
            </div>
            <p class="text-slate-500 max-w-xs">Agencia especializada en Paid Media y sistemas de escalabilidad para negocios digitales.</p>
        </div>
        <div class="flex gap-8">
            <a class="text-slate-400 hover:text-primary transition-colors" href="#">Instagram</a>
            <a class="text-slate-400 hover:text-primary transition-colors" href="#">LinkedIn</a>
            <a class="text-slate-400 hover:text-primary transition-colors" href="#">WhatsApp</a>
        </div>
        <div class="text-center md:text-right space-y-2">
            <p class="text-slate-500 text-sm">© 2024 Expert.Ads Agencia. Todos los derechos reservados.</p>
            <div class="flex items-center justify-center md:justify-end gap-2 text-primary/60 text-xs">
