---
// src/components/Header.astro
---
<header class="fixed top-0 w-full z-50 bg-background-dark/80 backdrop-blur-md border-b border-primary/10">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="text-primary">
                <span class="material-symbols-outlined text-4xl">insights</span>
            </div>
            <h2 class="text-xl font-black tracking-tighter uppercase italic">Expert<span class="text-primary">.</span>Ads Agencia</h2>
        </div>
        <button class="hidden md:flex bg-primary hover:bg-primary/90 text-white px-6 py-2.5 rounded-full font-bold transition-all transform hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(249,6,249,0.3)]">
            Quiero mi diagnóstico
        </button>
    </div>
</header>